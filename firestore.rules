rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny: no document is readable or writable unless
    // explicitly permitted by a rule below.

    // users/{uid} — onboarding profile, one doc per Firebase UID.
    // Only the authenticated owner may read or write their own document.
    // Cross-tenant access (user A reading/writing user B's doc) is denied.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
